database universidad {
    store at "reportes/uni.json";
}

use universidad;

table estudiantes {
    id: int;
    nombre: string;
    edad: int;
}

add estudiantes {
    id: 1,
    nombre: "Luigi",
    edad: 22
};

add estudiantes {
    id: 2,
    nombre: "Mario",
    edad: 45
};

add estudiantes {
    id: 3,
    nombre: "Toad",
    edad: 10
};


read estudiantes {
    fields: nombre, edad;
    filter: edad > 20;
};

update estudiantes {
    set: edad = 46;
    filter: nombre == "Mario";
};


read estudiantes {
    fields: nombre, edad;
    filter: nombre == "Mario";
};


table temp { i: int; }
add temp { i: 1 };
clear temp;